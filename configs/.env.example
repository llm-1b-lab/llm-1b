# ============================================================
# llm-1b 环境变量配置模板
# 使用方式：cp configs/.env.example .env 并填入真实值
# .env 文件已被 .gitignore 排除，不会被提交到仓库
# ============================================================

# 海纳数据平台认证（用于语料下载）
HAINA_DATAHUB_AK=your_access_key_here
HAINA_DATAHUB_SK=your_secret_key_here

# 数据与模型存储路径
LLM1B_DATA_DIR=/mnt/data
LLM1B_MODEL_DIR=/mnt/models

# wandb 日志（可选）
WANDB_API_KEY=your_wandb_key_here
